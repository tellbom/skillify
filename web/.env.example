# Skillify backend (T3.1) — see infra/ for how to run skillify-web locally.
VITE_DEV_HOST=0.0.0.0
VITE_DEV_PORT=5173
VITE_API_BASE=/api
# Vite development proxy target. Keep VITE_API_BASE=/api for same-origin browser requests.
VITE_API_PROXY_TARGET=http://127.0.0.1:8089

# M4 — Keycloak (frontend login). Placeholder values; real realm/client come from ops.
# Full realm issuer URL, e.g. https://sso.example.com/realms/internal
VITE_KEYCLOAK_REALM_URL=
# Fallback if VITE_KEYCLOAK_REALM_URL doesn't match the standard /realms/{realm} shape
VITE_KEYCLOAK_REALM=
VITE_KEYCLOAK_CLIENT_ID=skillify-web

# M4 — Rbac.Api (frontend-direct, per design decision in TASKS.md M4). Placeholder;
# real base URL/project code come from whoever operates the RBAC service.
VITE_RBAC_BASE_URL=http://127.0.0.1:5005
VITE_RBAC_PROJECT=skillify
