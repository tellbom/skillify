{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["baseline", "changes", "verification", "externalBehaviorChanged", "remainingRisks"],
  "properties": {
    "baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commands", "passed"],
      "properties": {
        "commands": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "passed": {"type": "boolean"}
      }
    },
    "changes": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commands", "passed"],
      "properties": {
        "commands": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "passed": {"type": "boolean"}
      }
    },
    "externalBehaviorChanged": {"const": false},
    "remainingRisks": {"type": "array", "items": {"type": "string", "minLength": 1}}
  }
}
