{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillify.local/schema/skill-manifest-v1.schema.json",
  "title": "Skillify skill.yaml manifest — v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifestVersion",
    "namespace",
    "name",
    "version",
    "description",
    "author",
    "license",
    "runtime",
    "targets"
  ],
  "properties": {
    "manifestVersion": {
      "const": 1
    },
    "namespace": {
      "type": "string",
      "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?$",
      "minLength": 1,
      "maxLength": 64
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?$",
      "minLength": 1,
      "maxLength": 64
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "author": {
      "oneOf": [
        {"type": "string", "minLength": 1},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["name"],
          "properties": {
            "name": {"type": "string", "minLength": 1},
            "email": {"type": "string", "format": "email"}
          }
        }
      ]
    },
    "license": {
      "type": "string",
      "minLength": 1
    },
    "runtime": {
      "type": "string",
      "enum": ["claude-agent-skill", "custom"]
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["claude", "opencode", "codex", "aider", "project"]
      }
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "python": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "default": []
        },
        "system": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "default": []
        },
        "skills": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?/[a-z0-9]([a-z0-9-]*[a-z0-9])?@.+$"
          },
          "default": []
        }
      }
    },
    "entrypoints": {
      "type": "object",
      "default": {}
    },
    "permissions": {
      "oneOf": [
        {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "readPaths": {"$ref": "#/$defs/pathAllowlist"},
            "writePaths": {"$ref": "#/$defs/pathAllowlist"},
            "commands": {
              "type": "object",
              "propertyNames": {"type": "string", "minLength": 1, "maxLength": 512},
              "additionalProperties": {"type": "string", "enum": ["allow", "ask", "deny"]}
            },
            "networkDomains": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 253,
                "pattern": "^(?!.*://)[^/@?#\\s]+$"
              }
            },
            "mcpServers": {"$ref": "#/$defs/namedAllowlist"},
            "databaseResources": {"$ref": "#/$defs/namedAllowlist"},
            "unattended": {"type": "boolean"},
            "confirm": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": ["read", "write", "command", "network", "mcp", "database", "credential"]
              }
            }
          }
        }
      ],
      "default": []
    },
    "tags": {
      "type": "array",
      "items": {"type": "string", "minLength": 1, "maxLength": 32},
      "default": []
    },
    "orchestration": {
      "type": "object",
      "default": {}
    },
    "reporting": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {"type": "boolean", "default": false}
      },
      "default": {"enabled": false}
    }
  },
  "$defs": {
    "pathAllowlist": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1024,
        "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\u0000\\\\]+$"
      }
    },
    "namedAllowlist": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128,
        "pattern": "^(?:\\*|[A-Za-z0-9][A-Za-z0-9._:/-]{0,127})$"
      }
    }
  }
}
