FORGEJO_DB_USER=forgejo
FORGEJO_DB_PASSWORD=forgejo
FORGEJO_DB_NAME=forgejo
FORGEJO_DOMAIN=localhost
FORGEJO_ROOT_URL=http://localhost:3000/
FORGEJO_HTTP_PORT=3000
FORGEJO_SSH_PORT=2222
FORGEJO_DISABLE_REGISTRATION=false
DEVPI_PORT=3141

# Docker CLI deployment images. PostgreSQL 12 matches the existing test data
# volume; changing a stateful image is an explicit maintenance operation.
SKILLIFY_POSTGRES_IMAGE=postgres:12
SKILLIFY_FORGEJO_IMAGE=codeberg.org/forgejo/forgejo:10
SKILLIFY_WEB_IMAGE=skillify-skillify-web:local
SKILLIFY_FRONTEND_IMAGE=skillify-frontend:local
SKILLIFY_DEVPI_IMAGE=skillify-devpi:local

# Skillify business tables live in a separate, externally managed DM8 schema.
# URL-encode reserved characters in the password before placing it in this URL.
SKILLIFY_INDEX_DB_URL=dm+dmPython://SKILLIFY_USER:URL_ENCODED_PASSWORD@dm8.example.internal:5236

# Backend JWT validation and frontend Keycloak login.
SKILLIFY_KEYCLOAK_REALM_URL=https://sso.example.internal/realms/internal
SKILLIFY_KEYCLOAK_JWKS_URL=
SKILLIFY_KEYCLOAK_AUDIENCE=skillify-web
# Generate two independent random values. Do not commit real values.
# SKILLIFY_ENDPOINT_DEVICE_SECRET=<endpoint bearer-token signing secret>
# SKILLIFY_ENDPOINT_TASK_SIGNING_SECRET=<task-envelope signing secret>
VITE_KEYCLOAK_REALM_URL=https://sso.example.internal/realms/internal
VITE_KEYCLOAK_REALM=
VITE_KEYCLOAK_CLIENT_ID=skillify-web

# Existing internal Rbac.Api used by the frontend menu and management views.
VITE_RBAC_BASE_URL=http://rbac.example.internal
VITE_RBAC_PROJECT=skillify

# Complete Skillify UI entry point.
SKILLIFY_HTTP_PORT=8080

# webhook service (T2.1) — required, no safe default; generate real values before `up`.
# SKILLIFY_FORGEJO_TOKEN=<Forgejo personal/bot access token, Settings -> Applications>
# SKILLIFY_WEBHOOK_SECRET=<random string; must match the secret set on the Forgejo webhook>
WEBHOOK_PORT=8088
